{
  "name": "cartographer",
  "version": "0.0.0",
  "description": "End-to-end trace explorer and debugger for XCM.",
  "type": "module",
  "bin": {
    "cartographer": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm coverage && pnpm depcheck && pnpm build",
    "infra:up": "node scripts/cartographer-local-xcm.mjs up",
    "infra:status": "node scripts/cartographer-local-xcm.mjs status",
    "infra:down": "node scripts/cartographer-local-xcm.mjs down",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --exclude '**/*.it.test.ts'",
    "test:debug-flow": "vitest run src/cli/debug-flow.it.test.ts",
    "test:it": "vitest run .it.test",
    "test:live": "pnpm run live:check:full && vitest run .it.test",
    "test:local-xcm": "vitest run scripts/cartographer-local-xcm.test.mjs",
    "coverage": "vitest run --coverage --exclude '**/*.it.test.ts'",
    "depcheck": "depcruise src --config .dependency-cruiser.cjs",
    "live:check:cli": "node scripts/cartographer-live.mjs check-cli",
    "live:check:client": "node scripts/cartographer-live.mjs check-client",
    "live:check:full": "node scripts/cartographer-live.mjs check-full",
    "live:xcm:cli": "pnpm run live:check:cli && pnpm build && node scripts/cartographer-live.mjs run-cli",
    "live:xcm:test": "pnpm run live:check:client && vitest run src/client/dry-run.it.test.ts",
    "xcm:send": "node scripts/cartographer-local-xcm.mjs send",
    "xcm:test": "node scripts/cartographer-local-xcm.mjs test",
    "xcm:cli": "pnpm build && node scripts/cartographer-local-xcm.mjs cli"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12",
    "polkadot-api": "^1"
  },
  "devDependencies": {
    "@acala-network/chopsticks": "1.5.0",
    "@polkadot-labs/hdkd": "0.0.28",
    "@polkadot-labs/hdkd-helpers": "0.0.30",
    "@types/node": "^20",
    "@vitest/coverage-v8": "2.1.9",
    "dependency-cruiser": "^16",
    "eslint": "^9",
    "eslint-plugin-sonarjs": "4.1.0",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  },
  "comment": "Dependency version ranges are starting points — verify latest stable and pin exact versions before committing a lockfile. polkadot-api (PAPI) is the chain client per ADR-0002."
}
