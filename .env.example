# Local/forked Chopsticks XCM workflow. These defaults target infra/chopsticks/.
CARTOGRAPHER_LOCAL_STATE_DIR=.cartographer-local
CARTOGRAPHER_LOCAL_EVIDENCE_DIR=_workspace/local-xcm
CARTOGRAPHER_LOCAL_RELAY_CONFIG=infra/chopsticks/westend.yml
CARTOGRAPHER_LOCAL_PARACHAIN_CONFIGS=infra/chopsticks/westend-asset-hub.yml,infra/chopsticks/westend-people.yml
CARTOGRAPHER_LOCAL_ORIGIN_RPC=ws://127.0.0.1:8000
CARTOGRAPHER_LOCAL_DEST_RPC=ws://127.0.0.1:8001
CARTOGRAPHER_LOCAL_RELAY_RPC=ws://127.0.0.1:8002
# Local dev SURI used for transaction signing. xcm-cli derives the matching SS58 address for DryRunApi.
CARTOGRAPHER_LOCAL_ACCOUNT=//Alice

# Optional override for make xcm-send / pnpm run xcm:send.
# Leave unset to generate the default verified PolkadotXcm.limited_teleport_assets call.
# When set, this must be a SCALE-encoded call valid on CARTOGRAPHER_LOCAL_ORIGIN_RPC.
# CARTOGRAPHER_LOCAL_CALL=0x...
CARTOGRAPHER_LOCAL_XCM_AMOUNT=10000000000

# Optional local workflow knobs.
CARTOGRAPHER_LOCAL_FORMAT=json
CARTOGRAPHER_LOCAL_BOOT_TIMEOUT_MS=120000
CARTOGRAPHER_LOCAL_HEALTH_TIMEOUT_MS=5000
CARTOGRAPHER_LOCAL_SEND_TIMEOUT_MS=120000

# Live integration endpoint. Replace every placeholder below before running live dry-run commands.
# The endpoint must be a WebSocket RPC that supports DryRunApi and XcmPaymentApi.
CARTOGRAPHER_IT_RPC=wss://asset-hub-polkadot-rpc.example

# Origin used as Signed origin in dry_run_call.
CARTOGRAPHER_IT_ACCOUNT=5...

# Generic SCALE-encoded call used by the client-level live evidence test.
CARTOGRAPHER_IT_CALL=0x...

# Known-success SCALE-encoded call used by orchestrator and CLI live tests.
CARTOGRAPHER_IT_CALL_OK=0x...

# Known-failing SCALE-encoded call used by orchestrator live tests.
CARTOGRAPHER_IT_CALL_FAIL=0x...

# Optional raw-XCM CLI handoff inputs. When CARTOGRAPHER_IT_XCM_FILE is set,
# `pnpm run live:xcm:cli` uses --xcm instead of --call and reads the origin from
# CARTOGRAPHER_IT_XCM_ORIGIN.
# CARTOGRAPHER_IT_XCM_ORIGIN={"parents":1,"interior":"Here"}
# CARTOGRAPHER_IT_XCM_FILE=./program.json

# Optional static registry inputs for CLI multi-hop handoff.
# CARTOGRAPHER_IT_REGISTRY=./registry.json
# CARTOGRAPHER_IT_MAX_DEPTH=4

# Optional output/result knobs.
CARTOGRAPHER_IT_RESULT_XCM_VERSION=4
CARTOGRAPHER_IT_FORMAT=json
